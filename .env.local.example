# ── Encryption ────────────────────────────────────────────────────────────────
# Required to save integration credentials. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# ── Slack (legacy webhook — used by the manual churn alert button) ─────────────
# If left unset, alerts are logged to the server console instead.
SLACK_WEBHOOK_URL=

# ── Slack (bot token — used by the Integrations page) ────────────────────────
# Create a Slack app at https://api.slack.com/apps, add the chat:write scope,
# install to your workspace, and copy the Bot User OAuth Token (xoxb-…).
# SLACK_BOT_TOKEN=

# ── Attio ─────────────────────────────────────────────────────────────────────
# API access token from https://app.attio.com/settings/api
# ATTIO_API_KEY=

# ── Google / Gmail OAuth 2.0 ──────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add the redirect URI below to "Authorised redirect URIs"
# 4. Enable the Gmail API for your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback
